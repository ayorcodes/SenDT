{
  "name": "sendt",
  "version": "0.0.1",
  "private": true,
  "packageManager": "pnpm@10.30.3",
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "lint": "turbo lint",
    "dev:api": "turbo dev --filter=@sendt/api",
    "dev:web": "turbo dev --filter=@sendt/web",
    "db:migrate": "turbo db:migrate --filter=@sendt/api",
    "db:studio": "turbo db:studio --filter=@sendt/api",
    "db:seed": "turbo db:seed --filter=@sendt/api"
  },
  "devDependencies": {
    "turbo": "^2.3.3",
    "typescript": "^5.6.3",
    "prettier": "^3.3.3"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@nestjs/core",
      "@prisma/engines",
      "bcrypt",
      "prisma",
      "sharp",
      "unrs-resolver"
    ]
  }
}
